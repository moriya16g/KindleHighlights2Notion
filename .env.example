# Kindle Highlights → Notion: Configuration
# Copy this file to .env and set your values
# cp .env.example .env

# --- Server Settings / サーバー設定 ---
# HOST: Bind address (localhost=local only, 0.0.0.0=public)
# HOST: バインドアドレス（localhost=ローカルのみ, 0.0.0.0=外部公開）
HOST=localhost
PORT=8000

# BASE_URL: Public URL for the bookmarklet (no trailing slash)
# BASE_URL: ブックマークレットの送信先URL（末尾スラッシュなし）
# Examples: https://example.com, http://myserver:8000
# Leave empty to auto-detect from HOST:PORT
BASE_URL=

# --- Basic Auth (recommended for public deployment) ---
# --- Basic 認証（外部公開時に推奨） ---
# Leave empty to disable / 空欄で認証なし
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
